# ── Required ──
AM_LLM_API_KEY=sk-...
AM_DEFAULT_CHAIN=devnet

# ── RPC ──
# Sui environment RPC URLs (at least one required)
AM_RPC_MAINNET=https://fullnode.mainnet.sui.io:443
AM_RPC_DEVNET=https://fullnode.devnet.sui.io:443
AM_RPC_TESTNET=https://fullnode.testnet.sui.io:443

# ── Sui binary (optional, auto-detected from PATH) ──
# AM_SUI_BIN=/usr/local/bin/sui

# ── LLM (defaults to DeepSeek) ──
AM_LLM_BASE_URL=https://api.deepseek.com
AM_LLM_MODEL=deepseek-chat

# ── Server ──
AM_HOST=0.0.0.0
AM_PORT=9003
AM_BASE_URL=http://localhost:9003

# ── x402 Payment (optional) ──
AM_WALLET_ADDRESS=
AM_FACILITATOR_URL=https://x402.org/facilitator
AM_CHAIN_NETWORK=eip155:84532

# ── ERC-8004 Registration (optional) ──
AM_PRIVATE_KEY=
AM_CHAIN_ID=84532
AM_RPC_URL=
AM_PINATA_JWT=
