# ── Required ──
AM_LLM_API_KEY=sk-...
AM_DEFAULT_CHAIN=devnet

# ── RPC ──
# Solana cluster RPC URLs (at least one required)
AM_RPC_MAINNET_BETA=https://api.mainnet-beta.solana.com
AM_RPC_DEVNET=https://api.devnet.solana.com
AM_RPC_TESTNET=https://api.testnet.solana.com

# ── Solana binary (optional, auto-detected from PATH) ──
# AM_SOLANA_BIN=/usr/local/bin/solana

# ── LLM (defaults to DeepSeek) ──
AM_LLM_BASE_URL=https://api.deepseek.com
AM_LLM_MODEL=deepseek-chat

# ── Server ──
AM_HOST=0.0.0.0
AM_PORT=9002
AM_BASE_URL=http://localhost:9002

# ── x402 Payment (optional) ──
AM_WALLET_ADDRESS=
AM_FACILITATOR_URL=https://x402.org/facilitator
AM_CHAIN_NETWORK=eip155:84532

# ── ERC-8004 Registration (optional) ──
AM_PRIVATE_KEY=
AM_CHAIN_ID=84532
AM_RPC_URL=
AM_PINATA_JWT=
