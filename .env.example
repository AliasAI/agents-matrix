# ── Required ──
AM_LLM_API_KEY=sk-...
AM_DEFAULT_CHAIN=base_sepolia

# ── RPC URLs (set for each chain you want to support) ──
# Testnets
AM_RPC_BASE_SEPOLIA=https://your-base-sepolia-rpc.quiknode.pro/key/
# Mainnets
AM_RPC_ETHEREUM=https://your-ethereum-rpc.quiknode.pro/key/
AM_RPC_ARBITRUM=https://your-arbitrum-rpc.quiknode.pro/key/
AM_RPC_BASE=https://your-base-rpc.quiknode.pro/key/
AM_RPC_POLYGON=https://your-polygon-rpc.quiknode.pro/key/
AM_RPC_OPTIMISM=https://your-optimism-rpc.quiknode.pro/key/
AM_RPC_BSC=https://your-bsc-rpc.quiknode.pro/key/
AM_RPC_AVALANCHE=https://your-avalanche-rpc.quiknode.pro/key/
AM_RPC_LINEA=
AM_RPC_SCROLL=
AM_RPC_ZKSYNC=
AM_RPC_BLAST=

# ── LLM (defaults to DeepSeek, any OpenAI-compatible API works) ──
AM_LLM_BASE_URL=https://api.deepseek.com
AM_LLM_MODEL=deepseek-chat

# ── Server (defaults work fine) ──
AM_HOST=0.0.0.0
AM_PORT=9000
AM_BASE_URL=http://localhost:9000

# ── x402 Payment (optional — leave empty to disable) ──
AM_WALLET_ADDRESS=
AM_FACILITATOR_URL=https://x402.org/facilitator
AM_CHAIN_NETWORK=eip155:84532

# ── ERC-8004 Registration (optional — only for ./scripts/register.sh) ──
AM_PRIVATE_KEY=
AM_CHAIN_ID=84532
AM_RPC_URL=
AM_PINATA_JWT=
